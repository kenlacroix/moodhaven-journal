# GHSA-67mh-4wv8-2f99 (esbuild CORS) resolved by upgrading to vite@8 in v0.8.4.
# audit-level left at default (moderate+).
# TipTap packages use exact peer dep pins between their own packages; legacy-peer-deps
# avoids ERESOLVE errors when all @tiptap/* are updated to the same minor together.
legacy-peer-deps=true
