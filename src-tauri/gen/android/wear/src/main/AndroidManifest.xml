<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Required: identifies this as a watch app -->
    <uses-feature android:name="android.hardware.type.watch" />

    <!-- Haptic feedback -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:label="@string/app_name"
        android:theme="@android:style/Theme.DeviceDefault">

        <!-- Required library for Wear OS -->
        <uses-library
            android:name="com.google.android.wearable"
            android:required="true" />

        <!--
          standalone="false": this is a companion app (requires paired phone app).
          Set to "true" if/when the watch app works without a phone.
        -->
        <meta-data
            android:name="com.google.android.wearable.standalone"
            android:value="false" />

        <!-- Main launcher activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:taskAffinity=""
            android:allowEmbedded="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
          FeedbackService: receives /feedback messages from the phone.
          The phone calls wearSendFeedback("saved") after persisting a signal;
          we respond with a haptic pulse to confirm receipt.
        -->
        <service
            android:name=".FeedbackService"
            android:exported="true">
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.MESSAGE_RECEIVED" />
                <data
                    android:host="*"
                    android:pathPrefix="/feedback"
                    android:scheme="wear" />
            </intent-filter>
        </service>

    </application>

</manifest>
