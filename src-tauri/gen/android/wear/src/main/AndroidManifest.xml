<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Required: identifies this as a watch app -->
    <uses-feature android:name="android.hardware.type.watch" />

    <!-- Haptic feedback -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Voice recording -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Optional heart rate snapshot at recording time -->
    <uses-permission android:name="android.permission.BODY_SENSORS" />

    <!-- Foreground service for tile actions -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />

    <application
        android:label="@string/app_name"
        android:theme="@style/Theme.MoodHaven">

        <!-- com.google.android.wearable was removed in Wear OS 3+; mark optional
             so the APK installs on Pixel Watch 3 (Wear OS 4). All actual APIs
             come from androidx.wear and play-services-wearable. -->
        <uses-library
            android:name="com.google.android.wearable"
            android:required="false" />

        <!--
          standalone="false": requires paired phone app.
          Set to "true" if/when the watch app can work offline fully.
        -->
        <meta-data
            android:name="com.google.android.wearable.standalone"
            android:value="false" />

        <!-- ── Activities ──────────────────────────────────────────────── -->

        <!-- Main launcher: mood picker -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:taskAffinity=""
            android:allowEmbedded="true"
            android:theme="@style/Theme.MoodHaven.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Recent moods history screen -->
        <activity
            android:name=".HistoryActivity"
            android:exported="false" />

        <!-- Breathing: mode detail (cycle adjuster + Begin) -->
        <activity
            android:name=".BreatheModeDetailActivity"
            android:exported="false" />

        <!-- Breathing: active session (full-screen ring animation) -->
        <activity
            android:name=".BreatheSessionActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Breathing: post-session summary (HR before/after + actions) -->
        <activity
            android:name=".BreatheSummaryActivity"
            android:exported="false" />

        <!--
          Tile action trampoline: launched by tile mood-button taps.
          Theme.Translucent keeps it invisible while showing confirmation.
        -->
        <activity
            android:name=".TileActionActivity"
            android:exported="true"
            android:taskAffinity=""
            android:allowEmbedded="true"
            android:theme="@style/Theme.MoodHaven.Translucent" />

        <!-- ── Services ────────────────────────────────────────────────── -->

        <!--
          FeedbackService: receives /feedback messages from the phone.
          Vibrates to confirm a signal was saved.
        -->
        <service
            android:name=".FeedbackService"
            android:exported="true">
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.MESSAGE_RECEIVED" />
                <data
                    android:host="*"
                    android:pathPrefix="/feedback"
                    android:scheme="wear" />
            </intent-filter>
        </service>

        <!--
          MoodTileService: provides the quick-access mood tile.
          Users add it via: Settings → Tiles → Add tile → MoodBloom
        -->
        <service
            android:name=".MoodTileService"
            android:exported="true"
            android:label="@string/tile_label"
            android:permission="com.google.android.wearable.permission.BIND_TILE_PROVIDER">
            <intent-filter>
                <action android:name="androidx.wear.tiles.action.BIND_TILE_PROVIDER" />
            </intent-filter>
            <!-- Shown in tile picker -->
            <meta-data
                android:name="androidx.wear.tiles.PREVIEW_ACTIVITY"
                android:value=".MainActivity" />
        </service>

        <!--
          MoodComplicationService: provides mood data to watch faces.
          Watch face users: long-press face → Complications → MoodBloom
        -->
        <service
            android:name=".MoodComplicationService"
            android:exported="true"
            android:label="@string/complication_label"
            android:permission="com.google.android.wearable.permission.BIND_COMPLICATION_PROVIDER">
            <intent-filter>
                <action android:name="android.support.wearable.complications.ACTION_COMPLICATION_UPDATE_REQUEST" />
            </intent-filter>
            <meta-data
                android:name="android.support.wearable.complications.SUPPORTED_TYPES"
                android:value="SHORT_TEXT,LONG_TEXT" />
            <!-- Update every 30 minutes (complication data is mood history, not live) -->
            <meta-data
                android:name="android.support.wearable.complications.UPDATE_PERIOD_SECONDS"
                android:value="1800" />
        </service>

    </application>

</manifest>
