<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- ── Swipe pages ─────────────────────────────────────────────────── -->

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- ── Page dots ───────────────────────────────────────────────────── -->

    <LinearLayout
        android:id="@+id/pageDots"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="10dp"
        android:orientation="horizontal"
        android:gravity="center">

        <View android:id="@+id/dot0" android:layout_width="5dp" android:layout_height="5dp"
            android:layout_marginEnd="4dp" android:background="@drawable/circle_dot" />
        <View android:id="@+id/dot1" android:layout_width="5dp" android:layout_height="5dp"
            android:layout_marginEnd="4dp" android:background="@drawable/circle_dot" />
        <View android:id="@+id/dot2" android:layout_width="5dp" android:layout_height="5dp"
            android:layout_marginEnd="4dp" android:background="@drawable/circle_dot" />
        <View android:id="@+id/dot3" android:layout_width="5dp" android:layout_height="5dp"
            android:background="@drawable/circle_dot" />

    </LinearLayout>

    <!-- ── Mood confirmation overlay ────────────────────────────────────── -->

    <FrameLayout
        android:id="@+id/confirmationOverlay"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FF10B981">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/confirmEmoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="52sp"
                android:gravity="center" />

            <TextView
                android:id="@+id/confirmMoodName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginTop="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mood logged ✓"
                android:textSize="11sp"
                android:textColor="#CCFFFFFF"
                android:gravity="center"
                android:layout_marginTop="4dp" />

            <!-- "Add voice note?" button — shown briefly after confirmation -->
            <TextView
                android:id="@+id/addNoteBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎙 Add a note"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:layout_marginTop="14dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:background="@drawable/btn_outline"
                android:visibility="gone" />

        </LinearLayout>

    </FrameLayout>

    <!-- ── Queued overlay (phone unreachable after mood tap) ────────────── -->

    <FrameLayout
        android:id="@+id/queuedOverlay"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FF1E293B">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/queuedEmoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="40sp"
                android:gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Saved for later"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginTop="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Syncs when phone is near"
                android:textSize="11sp"
                android:textColor="#88FFFFFF"
                android:gravity="center"
                android:layout_marginTop="4dp" />

        </LinearLayout>

    </FrameLayout>

</FrameLayout>
