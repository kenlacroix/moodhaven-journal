<?xml version="1.0" encoding="utf-8"?>
<!--
  Record page — primary watch UI.
  BoxInsetLayout inside ScrollView ensures round-screen insets are respected
  so content isn't clipped on a circular Wear OS display.
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/pageRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/wear_surface"
    android:fillViewport="true">

    <androidx.wear.widget.BoxInsetLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="30dp"
        android:paddingBottom="24dp"
        app:layout_boxedEdges="all">

        <!-- Long-press hint — appears briefly while recording -->
        <TextView
            android:id="@+id/longPressHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:visibility="gone"
            android:text="Hold to discard"
            android:textSize="9sp"
            android:textColor="@color/wear_text_primary_alpha27" />

        <!--
          116 dp outer frame = 96 dp button + 10 dp gap each side for the arc stroke.
        -->
        <FrameLayout
            android:layout_width="116dp"
            android:layout_height="116dp">

            <com.moodbloom.wear.ArcProgressView
                android:id="@+id/arcProgress"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <FrameLayout
                android:id="@+id/recordBtn"
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:layout_gravity="center"
                android:background="@drawable/ic_record_btn"
                android:foreground="?android:attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/recordIcon"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="🎙"
                    android:textSize="36sp"
                    android:gravity="center" />

            </FrameLayout>

        </FrameLayout>

        <!-- Duration counter — only visible while recording -->
        <TextView
            android:id="@+id/durationText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="0:00"
            android:textSize="22sp"
            android:textColor="@color/wear_text_primary"
            android:textStyle="bold"
            android:visibility="gone" />

        <!-- Status line -->
        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Tap to record"
            android:textSize="12sp"
            android:textColor="@color/wear_text_primary_alpha67"
            android:gravity="center" />

        <!-- Transfer / queue confirmation (appears briefly after stop) -->
        <TextView
            android:id="@+id/transferStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text=""
            android:textSize="10sp"
            android:textColor="@color/wear_text_primary_alpha40"
            android:gravity="center"
            android:visibility="gone" />

        <!-- Queue badge — shown when audio is waiting to sync -->
        <TextView
            android:id="@+id/queueBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:visibility="gone"
            android:text="● 0 queued"
            android:textSize="9sp"
            android:textColor="@color/mood_low_accent"
            android:paddingStart="4dp"
            android:paddingEnd="4dp" />

        <!-- Shortcut row: Mood + Breathe -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <TextView
                android:id="@+id/moodShortcutBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="😊 Mood"
                android:textSize="11sp"
                android:textColor="@color/wear_text_primary_alpha80"
                android:background="@drawable/ic_record_btn"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/breatheShortcutBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🧘 Breathe"
                android:textSize="11sp"
                android:textColor="@color/wear_text_primary_alpha80"
                android:background="@drawable/ic_record_btn"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

    </LinearLayout>

    </androidx.wear.widget.BoxInsetLayout>

</ScrollView>
