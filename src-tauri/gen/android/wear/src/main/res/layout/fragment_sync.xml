<?xml version="1.0" encoding="utf-8"?>
<!--
  Sync page — Phase 2 additions:
    • Recordings today counter
    • Last sync relative time
    • Voice memo queue shown separately from mood signal queue
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/wear_surface"
    android:fillViewport="true">

    <androidx.wear.widget.BoxInsetLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        app:layout_boxedEdges="all">

        <!-- Connection row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <View
                android:id="@+id/connectionDot"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/circle_dot"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/connectionStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Checking…"
                android:textSize="15sp"
                android:textColor="@color/wear_text_primary"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Phone name -->
        <TextView
            android:id="@+id/phoneName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="11sp"
            android:textColor="@color/wear_text_primary_alpha33"
            android:layout_marginBottom="8dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/wear_text_primary_alpha10"
            android:layout_marginBottom="12dp" />

        <!-- Recordings today -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📼  Today"
                android:textSize="12sp"
                android:textColor="@color/wear_text_primary_alpha67" />

            <TextView
                android:id="@+id/recordingsTodayText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 recordings"
                android:textSize="12sp"
                android:textColor="@color/wear_text_primary"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Last sync -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="⏱  Last sync"
                android:textSize="12sp"
                android:textColor="@color/wear_text_primary_alpha67" />

            <TextView
                android:id="@+id/lastSyncText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textSize="12sp"
                android:textColor="@color/wear_text_primary" />

        </LinearLayout>

        <!-- Voice memos queued -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🎙  Queued"
                android:textSize="12sp"
                android:textColor="@color/wear_text_primary_alpha67" />

            <TextView
                android:id="@+id/voiceQueueCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="12sp"
                android:textColor="@color/wear_text_primary" />

        </LinearLayout>

        <!-- Mood signals queued -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="😊  Moods"
                android:textSize="12sp"
                android:textColor="@color/wear_text_primary_alpha67" />

            <TextView
                android:id="@+id/moodQueueCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="12sp"
                android:textColor="@color/wear_text_primary" />

        </LinearLayout>

        <!-- Sync now button (only shown when queue > 0) -->
        <TextView
            android:id="@+id/retryBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:text="↑ Sync now"
            android:textSize="12sp"
            android:textColor="@color/brand_primary_500"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:background="@drawable/btn_outline"
            android:gravity="center" />

    </LinearLayout>

    </androidx.wear.widget.BoxInsetLayout>

</ScrollView>
