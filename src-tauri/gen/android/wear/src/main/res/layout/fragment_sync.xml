<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="36dp"
        android:paddingBottom="28dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp">

        <!-- Page label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sync Status"
            android:textSize="11sp"
            android:textColor="#55FFFFFF"
            android:layout_marginBottom="16dp" />

        <!-- Connection dot + status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <View
                android:id="@+id/connectionDot"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/circle_dot"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/connectionStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Checking…"
                android:textSize="15sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Phone name -->
        <TextView
            android:id="@+id/phoneName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="11sp"
            android:textColor="#66FFFFFF"
            android:layout_marginBottom="16dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#22FFFFFF"
            android:layout_marginBottom="14dp" />

        <!-- Queued count -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Pending signals"
                android:textSize="12sp"
                android:textColor="#AAFFFFFF" />

            <TextView
                android:id="@+id/queueCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Last logged -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="18dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Last logged"
                android:textSize="12sp"
                android:textColor="#AAFFFFFF" />

            <TextView
                android:id="@+id/lastLogged"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textSize="11sp"
                android:textColor="#AAFFFFFF" />

        </LinearLayout>

        <!-- Retry button (visible when queue > 0) -->
        <TextView
            android:id="@+id/retryBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:text="↑ Sync now"
            android:textSize="12sp"
            android:textColor="#FF8B5CF6"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:background="@drawable/btn_outline"
            android:gravity="center" />

    </LinearLayout>

</ScrollView>
