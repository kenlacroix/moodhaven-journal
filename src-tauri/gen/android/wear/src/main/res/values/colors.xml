<?xml version="1.0" encoding="utf-8"?>
<!--
  MoodHaven brand colors for the Wear OS companion.

  Mirrors the desktop app's primary violet scale and the website's
  warm cream / accent orange. See DESIGN.md at the repo root for the
  canonical brand definition.

  Wear OS displays often run on OLED, so deep blacks for backgrounds
  remain the right choice (battery + contrast). Brand colors are used
  for accents, active states, and key interactions — not full surfaces.
-->
<resources>

  <!-- Primary (violet) scale — matches tailwind.config.js primary tokens -->
  <color name="brand_primary_50">#F5F3FF</color>
  <color name="brand_primary_100">#EDE9FE</color>
  <color name="brand_primary_200">#DDD6FE</color>
  <color name="brand_primary_300">#C4B5FD</color>
  <color name="brand_primary_400">#A78BFA</color>
  <color name="brand_primary_500">#8B5CF6</color>
  <color name="brand_primary_600">#7C3AED</color>
  <color name="brand_primary_700">#6D28D9</color>
  <color name="brand_primary_800">#5B21B6</color>
  <color name="brand_primary_900">#4C1D95</color>
  <color name="brand_primary_950">#2E1065</color>

  <!-- Accent (CTA orange) — matches website -->
  <color name="brand_accent_cta">#F28C38</color>

  <!-- Warm cream (website page background) -->
  <color name="brand_cream">#F3F0EA</color>

  <!-- Mood scale (matches DESIGN.md mood tokens, only for mood UI) -->
  <color name="mood_struggling">#F43F5E</color>
  <color name="mood_low">#FB923C</color>
  <color name="mood_okay">#FBBF24</color>
  <color name="mood_good">#A3E635</color>
  <color name="mood_great">#10B981</color>

  <!-- Wear OS surfaces (OLED-friendly deep neutrals) -->
  <color name="wear_surface">#000000</color>
  <color name="wear_surface_elevated">#161616</color>
  <color name="wear_surface_overlay">#CC000000</color>
  <color name="wear_divider">#333333</color>

  <!-- Wear OS text -->
  <color name="wear_text_primary">#FFFFFF</color>
  <color name="wear_text_secondary">#CCCCCC</color>
  <color name="wear_text_tertiary">#A0A0A0</color>
  <color name="wear_text_muted">#808080</color>

  <!-- Recording state (used for active record button) -->
  <color name="wear_recording">#EF4444</color>

  <!-- Brand-tinted button outlines (semi-transparent violet) -->
  <color name="brand_primary_500_alpha33">#558B5CF6</color>
  <color name="brand_primary_500_alpha20">#338B5CF6</color>
  <color name="brand_primary_300_alpha33">#55C4B5FD</color>

  <!-- Semi-transparent white overlays (text hints, subtitles) -->
  <color name="wear_text_primary_alpha10">#1AFFFFFF</color>
  <color name="wear_text_primary_alpha27">#44FFFFFF</color>
  <color name="wear_text_primary_alpha33">#55FFFFFF</color>
  <color name="wear_text_primary_alpha40">#66FFFFFF</color>
  <color name="wear_text_primary_alpha53">#88FFFFFF</color>
  <color name="wear_text_primary_alpha67">#AAFFFFFF</color>
  <color name="wear_text_primary_alpha80">#CCFFFFFF</color>

  <!-- Additional surface variants -->
  <color name="wear_surface_deep">#1A1A2E</color>
  <color name="wear_surface_card">#222222</color>
  <color name="wear_surface_card_alt">#1F2937</color>
  <color name="wear_surface_dismiss">#374151</color>

  <!-- Mood queued overlay background -->
  <color name="wear_mood_queued_bg">#1E293B</color>

  <!-- Breathing suggestion chip (amber) -->
